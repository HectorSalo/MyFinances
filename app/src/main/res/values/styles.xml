<resources>

    <style name="NegativeButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#4db6ac</item>
    </style>

    <style name="PositiveButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#4db6ac</item>
    </style>

    <style name="TextAppearance.Convertidor" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:textColorHint">@color/colorPrimaryDark</item>
    </style>

    <style name="ShapeAppearanceOverlay.MyFinances.Button.Rounded" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Splash" parent="Theme.MyFinances">
        <item name="android:windowBackground">@drawable/background_splash</item>
        <item name="android:statusBarColor">?attr/colorOnPrimary</item>
    </style>

    <style name="ShapeAppearance.MyApp.BottomSheet" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="Widget.MyFinances.Calculator.ToggleButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/calc_toggle_background_color</item>
        <item name="strokeColor">@color/calc_toggle_stroke_color</item>
        <item name="android:textColor">@color/calc_toggle_text_color</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>
